rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ------------------------------------------------------------------------
    // Primitives & Identity Helpers
    // ------------------------------------------------------------------------
    function isValidId(id) { 
      return id is string && id.size() <= 128; 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isOwner(uid) { 
      return isSignedIn() && request.auth.uid == uid; 
    }
    
    function getUserRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && request.auth.token.email in ["aikennavas@gmail.com", "vantoniomolina@gmail.com", "vinumsanguinisetlacrimarum3@gmail.com", "admin@cantv.com.ve", "asistente@cantv.com.ve", "aiknav@cantv.com.ve"]) ||
        getUserRole() == 'admin'
      );
    }
    
    function isManager() {
      return isAdmin() || (isSignedIn() && getUserRole() == 'supervisor');
    }
    
    function isAllowedRoleForUser(email, role) {
      return role == 'tecnico' || role == 'unauthorized' || role == 'user' ||
             (role == 'supervisor' && (email.endsWith('@cantv.com.ve') || email.endsWith('@cantv.net') || email.endsWith('@CANTV.COM.VE') || email.endsWith('@CANTV.NET') || email in ["aikennavas@gmail.com", "vantoniomolina@gmail.com", "vinumsanguinisetlacrimarum3@gmail.com", "admin@cantv.com.ve", "asistente@cantv.com.ve", "aiknav@cantv.com.ve"])) ||
             (role == 'admin' && email in ["aikennavas@gmail.com", "vantoniomolina@gmail.com", "vinumsanguinisetlacrimarum3@gmail.com", "admin@cantv.com.ve", "asistente@cantv.com.ve", "aiknav@cantv.com.ve"]);
    }
    
    // ------------------------------------------------------------------------
    // Global Safety Net
    // ------------------------------------------------------------------------
    match /{document=**} { 
      allow read, write: if false; 
    }

    // ------------------------------------------------------------------------
    // Users Collection (PII)
    // ------------------------------------------------------------------------
    function isValidUserProfile(data) {
      return data.size() >= 5 && data.size() <= 12 &&
             data.keys().hasAll(['uid', 'email', 'displayName', 'role', 'createdAt']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['admin', 'supervisor', 'tecnico', 'unauthorized', 'user'] &&
             (!('allowPasswordChange' in data) || data.allowPasswordChange is bool) &&
             (!('department' in data) || data.department is string || data.department == null) &&
             (!('photoURL' in data) || data.photoURL is string || data.photoURL == null) &&
             data.createdAt is timestamp;
    }

    // ------------------------------------------------------------------------
    // System Config
    // ------------------------------------------------------------------------
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isManager());
      allow list: if isManager();
      
      allow create: if isValidId(userId) && (isOwner(userId) || isManager()) && 
                    isValidUserProfile(incoming()) &&
                    ('email' in request.auth.token) &&
                    (!('role' in incoming()) || isAllowedRoleForUser(request.auth.token.email, incoming().role));
                    
      allow update: if isValidId(userId) && (isOwner(userId) || isManager()) && 
                    isValidUserProfile(incoming());
                    
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------------
    // Technicians Collection
    // ------------------------------------------------------------------------
    function isValidTechnician(data) {
      return data.size() >= 1 && data.size() <= 30 &&
             data.name is string &&
             (!('employeeId' in data) || data.employeeId is string) &&
             (!('specialty' in data) || data.specialty is string) &&
             (!('idCard' in data) || data.idCard is string) &&
             (!('phoneNumber' in data) || data.phoneNumber is string) &&
             (!('status' in data) || data.status is string) &&
             (!('photoURL' in data) || data.photoURL is string || data.photoURL == null) &&
             (!('role' in data) || data.role is string) &&
             (!('email' in data) || data.email is string) &&
             (!('department' in data) || data.department is string) &&
             (!('uid' in data) || data.uid is string || data.uid == null) &&
             (!('createdAt' in data) || data.createdAt is timestamp || data.createdAt is string) &&
             (!('isDeleted' in data) || data.isDeleted is bool) &&
             (!('deletedAt' in data) || (data.deletedAt is timestamp || data.deletedAt == null || data.deletedAt is string)) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt is string);
    }

    function isSelfTechnician(techData) {
      return isSignedIn() && 
             (
                ('uid' in techData && techData.uid == request.auth.uid) || 
                ('email' in techData && 'email' in request.auth.token && techData.email.lower() == request.auth.token.email.lower())
             );
    }

    match /technicians/{techId} {
      allow get: if isValidId(techId) && isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isValidId(techId) && isManager() && isValidTechnician(incoming());
      
      allow update: if isValidId(techId) && isValidTechnician(incoming()) &&
                    (
                      isManager() || 
                      (
                        isSelfTechnician(existing()) &&
                        (!('role' in existing()) || incoming().role == existing().role) &&
                        (!('employeeId' in existing()) || incoming().employeeId == existing().employeeId) &&
                        (!('isDeleted' in existing()) || incoming().isDeleted == existing().isDeleted)
                      )
                    ) &&
                    ( (!('createdAt' in existing()) && !('createdAt' in incoming())) || 
                      (incoming().createdAt == existing().createdAt) );
                    
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------------
    // Activities Collection
    // ------------------------------------------------------------------------
    function isValidActivity(data) {
      return data.size() >= 1 && data.size() <= 50 &&
             data.title is string &&
             (!('description' in data) || data.description == null || data.description is string) &&
             (!('type' in data) || data.type == null || data.type is string) &&
             (!('status' in data) || data.status == null || data.status is string) &&
             (!('hasPerDiem' in data) || data.hasPerDiem == null || data.hasPerDiem is bool) &&
             (!('date' in data) || data.date == null || data.date is timestamp || data.date is string) &&
             (!('createdAt' in data) || data.createdAt == null || data.createdAt is timestamp || data.createdAt is string) &&
             (!('technicianId' in data) || data.technicianId == null || data.technicianId is string) &&
             (!('technicianName' in data) || data.technicianName == null || data.technicianName is string) &&
             (!('participants' in data) || data.participants == null || data.participants is list) &&
             (!('notes' in data) || data.notes == null || data.notes is list) &&
             (!('isDeleted' in data) || data.isDeleted == null || data.isDeleted is bool) &&
             (!('deletedAt' in data) || data.deletedAt == null || data.deletedAt is timestamp || data.deletedAt is string) &&
             (!('updatedAt' in data) || data.updatedAt == null || data.updatedAt is timestamp || data.updatedAt is string) &&
             (!('adminId' in data) || data.adminId == null || data.adminId is string) &&
             (!('overtimeHours' in data) || data.overtimeHours == null || data.overtimeHours is number) &&
             (!('perDiemAmount' in data) || data.perDiemAmount == null || (data.perDiemAmount is number && data.perDiemAmount >= 0)) &&
             (!('startTime' in data) || data.startTime == null || data.startTime is string) &&
             (!('endTime' in data) || data.endTime == null || data.endTime is string) &&
             (!('incidentNumber' in data) || data.incidentNumber == null || data.incidentNumber is string) &&
             (!('code' in data) || data.code == null || data.code is string) &&
             (!('cause' in data) || data.cause == null || data.cause is string) &&
             (!('fleet' in data) || data.fleet == null || data.fleet is string);
    }

    function isParticipating(data) {
      return (data.adminId == request.auth.uid) || 
             (request.auth.token != null && 'name' in request.auth.token && data.participants != null && request.auth.token.name in data.participants);
    }

    match /activities/{activityId} {
      allow get: if isValidId(activityId) && isSignedIn() && (isManager() || isParticipating(resource.data));
      allow list: if isSignedIn();
      
      allow create: if isValidId(activityId) && isSignedIn() && isValidActivity(incoming()) && (getUserRole() != 'tecnico' || incoming().adminId == request.auth.uid);
      
      allow update: if isValidId(activityId) && 
                    isSignedIn() && 
                    isValidActivity(incoming()) &&
                    (
                      isManager() 
                      || 
                      (
                        isParticipating(existing()) && 
                        existing().status != 'approved'
                      )
                    ) &&
                    ( (!('createdAt' in existing()) && !('createdAt' in incoming())) || 
                      (incoming().createdAt == existing().createdAt) );
                      
      allow delete: if isManager();
    }

    // ------------------------------------------------------------------------
    // Notifications Collection
    // ------------------------------------------------------------------------
    function isValidNotification(data) {
      return data.size() >= 3 && data.size() <= 18 &&
             data.keys().hasAll(['type', 'message', 'createdAt']) &&
             data.type is string && data.type.size() <= 50 &&
             data.message is string && data.message.size() <= 600 &&
             data.createdAt is timestamp &&
             (!('readBy' in data) || (data.readBy is list && data.readBy.size() <= 1000)) &&
             (!('userId' in data) || data.userId == null || data.userId is string) &&
             (!('userName' in data) || data.userName == null || data.userName is string) &&
             (!('severity' in data) || data.severity == null || data.severity in ['normal', 'medium', 'high']) &&
             (!('technician' in data) || data.technician == null || data.technician is string) &&
             (!('week' in data) || data.week == null || data.week is string) &&
             (!('date' in data) || data.date == null || data.date is string) &&
             (!('scope' in data) || data.scope in ['global', 'departmental', 'personal']) &&
             (!('targetRole' in data) || data.targetRole in ['admin', 'supervisor', 'tecnico', 'all']) &&
             (!('targetUserId' in data) || data.targetUserId == null || data.targetUserId is string) &&
             (!('relatedId' in data) || data.relatedId == null || data.relatedId is string) &&
             (!('oldValue' in data) || data.oldValue == null || data.oldValue is string) &&
             (!('newValue' in data) || data.newValue == null || data.newValue is string) &&
             (!('userRole' in data) || data.userRole == null || data.userRole is string) &&
             (!('department' in data) || data.department == null || data.department is string);
    }

    match /notifications/{notifId} {
      allow get: if isValidId(notifId) && isSignedIn() && (
        isAdmin() ||
        (getUserRole() == 'supervisor' && (resource.data.scope == 'departmental' || resource.data.targetRole == 'supervisor' || resource.data.scope == 'global')) ||
        (getUserRole() == 'tecnico' && resource.data.targetUserId == request.auth.uid)
      );
      allow list: if isSignedIn() && (
        isAdmin() ||
        (getUserRole() == 'supervisor') ||
        (getUserRole() == 'tecnico' && resource.data.targetUserId == request.auth.uid)
      );
      
      allow create: if isValidId(notifId) && isSignedIn() && isValidNotification(incoming());
      
      allow update: if isValidId(notifId) && isSignedIn() && 
                    incoming().createdAt == existing().createdAt &&
                    incoming().type == existing().type &&
                    incoming().message == existing().message &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['readBy']) &&
                    incoming().readBy is list;
                     
      allow delete: if isAdmin();
    }

    // ------------------------------------------------------------------------
    // Test Connection Connection
    // ------------------------------------------------------------------------
    match /test/connection {
      allow read: if true;
    }
  }
}
